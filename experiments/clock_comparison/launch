#!/bin/ruby

require 'optparse'

if ARGV.size != 5
    puts "Usage: ./launch position_files clocks1 clocks2 threads nodes\n\n"
    puts "Simulates games with one thread against the given number of threads with the given clock time limit starting at the given positions, repeating the given number of times."
    exit 1
end

trial=`date +%s`
trial.chomp!

positions = ARGV[0].split(" ")
clocks1 = ARGV[1].split(" ")
clocks2 = ARGV[2].split(" ")
threads = ARGV[3].split(" ")
nodes = ARGV[4]

`mkdir -p output`
`mkdir -p output/#{trial}`

dir = Dir.pwd
Dir.chdir("../framework")

positions.each do |pos|
    pos_file = "../positions/#{pos}"
    clocks1.each do |clock1|
        clocks2.each do |clock2|
            threads.each do |thread_count|
                args = "#{thread_count} #{thread_count} ../../bin/stockfish-original #{pos_file} --clock1 #{clock1} --clock2 #{clock2}"
                `../framework/launch_positions #{dir}/output/#{trial}/#{pos}__#{clock1}__#{clock2}__#{thread_count} #{pos_file} #{nodes} \"#{args}\"`
                puts "Queued: Pos #{pos}, Clock 1 #{clock1}, Clock 2 #{clock2}, Thread #{thread_count}"
            end
        end
    end
end