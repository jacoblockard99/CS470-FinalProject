#!/bin/ruby

out = ""

`mkdir -p output`

Dir.each_child("output") do |item|
    Dir.each_child("output/#{item}") do |trial|
        pos, threads, turn = item.split("_")
        path = File.join("output", item, trial)
        lines = `../framework/aggregate #{path}`.split("\n")

        pos = "pos_#{pos}"
        threads = threads[2..-1]
        turn = "0.#{turn[5..-1]}"

        next if lines.empty?

        one, two, draw = lines.first.split(" ")
        out += "#{trial} #{pos} #{threads} #{turn} #{one} #{two} #{draw} #{one.to_i+two.to_i+draw.to_i}\n"
    end
end

`rm -f results.txt`
`cp saved.txt results.txt`
File.write("results.txt", out, mode: 'a+')