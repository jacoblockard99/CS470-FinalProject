#!/bin/ruby

require 'optparse'

if ARGV.size != 5
    puts "Usage: ./launch position_files opponent_threads depth1 depth2 nodes\n\n"
    puts "Simulates games with one thread against the given numbers of threads with the given depth limits starting at the given positions."
    puts "Each argument is a space-delimited list of values. All permutations of the given options will be queued."
    puts "The given number of SLURM jobs will be queued for each permutation; the work will be split among the jobs."
    exit 1
end

trial=`date +%s`
trial.chomp!

positions = ARGV[0].split(" ")
threads = ARGV[1].split(" ")
depths1 = ARGV[2].split(" ")
depths2 = ARGV[3].split(" ")
nodes = ARGV[4]

`mkdir -p output`
`mkdir -p output/#{trial}`

dir = Dir.pwd
Dir.chdir("../framework")

positions.each do |pos|
    pos_file = "../positions/#{pos}"
    threads.each do |thread_count|
        depths1.each do |depth1|
            depths2.each do |depth2|
                args = "1 #{thread_count} ../../bin/stockfish-original #{pos_file} --depth1 #{depth1} --depth2 #{depth2}"
                `../framework/launch_positions #{dir}/output/#{trial}/#{pos}__#{thread_count}__#{depth1}__#{depth2} #{pos_file} #{nodes} \"#{args}\"`
                puts "Queued: Pos #{pos}, Thread #{thread_count}, Depth1 #{depth1}, Depth2 #{depth2}"
            end
        end
    end
end