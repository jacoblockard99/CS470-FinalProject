#!/bin/ruby

require 'optparse'

if ARGV.size != 4
    puts "Usage: ./launch position_files threads nodes_limit nodes\n\n"
    puts "Simulates games with the given numbers of threads (each engine has the same number of threads) with the given node limit starting at the given positions."
    puts "Each argument is a space-delimited list of values. All permutations of the given options will be queued."
    puts "The given number of SLURM jobs will be queued for each permutation; the work will be split among the jobs."
    exit 1
end

trial=`date +%s`
trial.chomp!

positions = ARGV[0].split(" ")
threads = ARGV[1].split(" ")
nodes_limit = ARGV[2].split(" ")
nodes = ARGV[3]

`mkdir -p output`
`mkdir -p output/#{trial}`

dir = Dir.pwd
Dir.chdir("../framework")

positions.each do |pos|
    pos_file = "../positions/#{pos}"
    threads.each do |thread_count|
        nodes_limit.each do |nodes_limit|
            args = "#{thread_count} #{thread_count} ../../bin/stockfish-original #{pos_file} --nodes1 #{nodes_limit} --nodes2 #{nodes_limit}"
            `../framework/launch_positions #{dir}/output/#{trial}/#{pos}__#{thread_count}__#{nodes_limit} #{pos_file} #{nodes} \"#{args}\"`
            puts "Queued: Pos #{pos}, Thread #{thread_count}, Nodes #{nodes_limit}"
        end
    end
end